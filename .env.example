APP_NAME="AdmisionEscolar"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL (Laragon: crear BD y ajustar credenciales)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=admision_escolar
DB_USERNAME=postgres
DB_PASSWORD="BVB5b6c76"

# SQLite solo para pruebas locales rápidas (opcional)
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
# Con `npm run dev`, Vite usa proxy a Laravel; deja vacío o usa /api/v1
VITE_API_URL=/api/v1

# Google Maps (Places + mapa). Opcional: sin clave se usa OpenStreetMap.
# Habilitar: Maps JavaScript API + Places API en Google Cloud Console.
GOOGLE_MAPS_API_KEY=

# Asistente conversacional (opcional). Sin clave usa respuestas guiadas locales.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Usuario administrador inicial (DatabaseSeeder)
DEFAULT_ADMIN_EMAIL=admin@sistema.test
DEFAULT_ADMIN_PASSWORD=Admin123!
